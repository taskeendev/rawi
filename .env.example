DB_PASSWORD=your_db_password

# Neon (production)
DB_URL=jdbc:postgresql://your-host.neon.tech/neondb?sslmode=require
DB_USERNAME=neondb_owner

# Groq
GROQ_API_KEY=your_groq_api_key

